############################################
# IDE / editor folders (any depth)
############################################
**/.idea/
**/*.iml
**/*.ipr
**/*.iws
**/.vscode/
**/.fleet/
**/.settings/
**/.project
**/.classpath

############################################
# JetBrains / IntelliJ tooling
############################################
**/out/
**/.idea_modules/
**/.kotlin/
**/.gradle/
**/cmake-build-*/
**/.run/

############################################
# OS junk
############################################
**/.DS_Store
**/Thumbs.db

############################################
# Env / secrets (any depth)
############################################
**/.env
**/.env.*
**/*.env
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.jks
**/id_rsa
**/id_rsa.pub

############################################
# Java / Maven / Gradle build artifacts
############################################
**/target/
**/*.class
**/*.jar
**/*.war
**/*.ear
**/hs_err_pid*
**/dependency-reduced-pom.xml

############################################
# Node / frontend build/cache (any depth)
############################################
**/node_modules/
**/dist/
**/build/
**/.next/
**/.cache/
**/.npm/
**/.pnpm-store/
**/.yarn/
**/coverage/
**/*.tsbuildinfo

############################################
# Python (any depth)
############################################
**/__pycache__/
**/*.py[cod]
**/.venv/
**/venv/
**/.mypy_cache/
**/.pytest_cache/

############################################
# Terraform (any depth)
############################################
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.*
**/*.tfvars
**/*.tfvars.json

############################################
# Logs
############################################
**/*.log

############################################
# Your custom directories to never share (any depth)
############################################
**/IDEA/
**/code/
# **/secrets/
# **/private/
# **/tmp/
# **/data/